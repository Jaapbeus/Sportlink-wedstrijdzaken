#!/bin/bash
# Pre-commit hook: scan staged files for sensitive data before committing.
# Patterns are loaded from .githooks/sensitive-patterns.txt (not tracked by git).

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PATTERN_FILE="$SCRIPT_DIR/sensitive-patterns.txt"

echo "🔍 Scanning staged files for sensitive data..."

if [ ! -f "$PATTERN_FILE" ]; then
  echo "⚠️  Pattern file not found: $PATTERN_FILE"
  echo "   Create it with one regex pattern per line."
  echo "   Commit allowed (no patterns to check)."
  exit 0
fi

FOUND_ISSUE=0
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  echo "✅ No staged files to scan."
  exit 0
fi

while IFS= read -r pattern || [ -n "$pattern" ]; do
  [ -z "$pattern" ] && continue
  [[ "$pattern" =~ ^# ]] && continue
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    if git show ":$file" 2>/dev/null | grep -qiE "$pattern"; then
      echo ""
      echo "❌ SENSITIVE DATA DETECTED"
      echo "   File   : $file"
      echo "   Pattern: $pattern"
      FOUND_ISSUE=1
    fi
  done <<< "$STAGED_FILES"
done < "$PATTERN_FILE"

if [ "$FOUND_ISSUE" -eq 1 ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  COMMIT BLOCKED — sensitive data found in staged files.     ║"
  echo "║  Remove the sensitive data and stage again.                 ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

echo "✅ No sensitive data detected. Commit allowed."
exit 0
