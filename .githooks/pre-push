#!/bin/bash
# Pre-push hook: scan all tracked files for sensitive data before pushing to GitHub.
# Patterns are loaded from .githooks/sensitive-patterns.txt (not tracked by git).

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PATTERN_FILE="$SCRIPT_DIR/sensitive-patterns.txt"

REMOTE_URL="$2"
echo "🔍 Scanning for sensitive data before push to: $REMOTE_URL"

if [ ! -f "$PATTERN_FILE" ]; then
  echo "⚠️  Pattern file not found: $PATTERN_FILE"
  echo "   Create it with one regex pattern per line."
  echo "   Push allowed (no patterns to check)."
  exit 0
fi

# Load patterns from file into array
PATTERNS=()
while IFS= read -r line || [ -n "$line" ]; do
  [ -z "$line" ] && continue
  [[ "$line" =~ ^# ]] && continue
  PATTERNS+=("$line")
done < "$PATTERN_FILE"

FOUND_ISSUE=0

while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    RANGE_SPEC="$local_sha"
  else
    RANGE_SPEC="$remote_sha..$local_sha"
  fi

  CHANGED_FILES=$(git diff --name-only "$RANGE_SPEC" 2>/dev/null || git show --name-only --format="" "$local_sha" 2>/dev/null)

  for pattern in "${PATTERNS[@]}"; do
    while IFS= read -r file; do
      [ -z "$file" ] && continue
      [ ! -f "$file" ] && continue
      if git show "$local_sha:$file" 2>/dev/null | grep -qiE "$pattern"; then
        echo ""
        echo "❌ SENSITIVE DATA IN COMMIT"
        echo "   File   : $file"
        echo "   Pattern: $pattern"
        FOUND_ISSUE=1
      fi
    done <<< "$CHANGED_FILES"
  done
done

echo ""
echo "🔍 Scanning all tracked working-tree files..."

for pattern in "${PATTERNS[@]}"; do
  MATCHES=$(git ls-files | xargs grep -liE "$pattern" 2>/dev/null || true)
  if [ -n "$MATCHES" ]; then
    echo ""
    echo "❌ SENSITIVE DATA IN TRACKED FILE"
    echo "   Pattern : $pattern"
    while IFS= read -r match; do
      echo "     - $match"
    done <<< "$MATCHES"
    FOUND_ISSUE=1
  fi
done

if [ "$FOUND_ISSUE" -eq 1 ]; then
  echo ""
  echo "╔══════════════════════════════════════════════════════════════╗"
  echo "║  PUSH BLOCKED — sensitive data found.                       ║"
  echo "║  Fix the issues above, then push again.                     ║"
  echo "╚══════════════════════════════════════════════════════════════╝"
  echo ""
  exit 1
fi

echo "✅ No sensitive data detected. Push allowed."
exit 0
