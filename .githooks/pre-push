#!/bin/bash
# Pre-push hook: scan alle tracked bestanden op secrets/PII voor push naar remote.
# Vereist: git config core.hooksPath .githooks (eenmalig per developer)

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PATTERN_FILE="$SCRIPT_DIR/sensitive-patterns.txt"
REMOTE_URL="$2"

echo "Scanning repository before push to: $REMOTE_URL"

FOUND_ISSUE=0

# ── 1. Blokkeer data-bestanden in working tree ────────────────────────────────
BLOCKED_EXT_PATTERN="\.(csv|xlsx|xls|xlsm|mdb|accdb)$"
TRACKED_DATA_FILES=$(git ls-files | grep -iE "$BLOCKED_EXT_PATTERN" || true)
if [ -n "$TRACKED_DATA_FILES" ]; then
  echo ""
  echo "BLOCKED: Data files are tracked by git:"
  while IFS= read -r f; do echo "  $f"; done <<< "$TRACKED_DATA_FILES"
  echo "  These may contain personal data (AVG/GDPR). Remove from git tracking."
  FOUND_ISSUE=1
fi

# ── 2. Scan commits die gepusht worden op secrets ────────────────────────────
while read local_ref local_sha remote_ref remote_sha; do
  [ "$local_sha" = "0000000000000000000000000000000000000000" ] && continue

  if [ "$remote_sha" = "0000000000000000000000000000000000000000" ]; then
    # Nieuwe branch: scan de bestanden in de tip-commit (vs parent), niet vs working tree.
    RANGE_SPEC="${local_sha}^..${local_sha}"
  else
    RANGE_SPEC="$remote_sha..$local_sha"
  fi

  CHANGED_FILES=$(git diff --name-only "$RANGE_SPEC" 2>/dev/null || git show --name-only --format="" "$local_sha" 2>/dev/null)

  # Blokkeer data-bestanden in commits
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    if echo "$file" | grep -qiE "$BLOCKED_EXT_PATTERN"; then
      echo ""
      echo "BLOCKED: Data file in commit being pushed"
      echo "  File: $file"
      FOUND_ISSUE=1
    fi
  done <<< "$CHANGED_FILES"

  # Pattern-based scan op commits
  if [ -f "$PATTERN_FILE" ]; then
    while IFS= read -r pattern || [ -n "$pattern" ]; do
      [ -z "$pattern" ] && continue
      [[ "$pattern" =~ ^# ]] && continue
      while IFS= read -r file; do
        [ -z "$file" ] && continue
        # Sla configuratie- en template-bestanden over
        if echo "$file" | grep -qE "(sensitive-patterns\.template\.txt|\.gitleaks\.toml|pre-commit|pre-push|security-scan\.yml)$"; then
          continue
        fi
        if git show "$local_sha:$file" 2>/dev/null | grep -qiE "$pattern"; then
          echo ""
          echo "BLOCKED: Sensitive pattern in commit"
          echo "  File   : $file"
          echo "  Pattern: $pattern"
          FOUND_ISSUE=1
        fi
      done <<< "$CHANGED_FILES"
    done < "$PATTERN_FILE"
  fi
done

# ── 3. Gebruik gitleaks indien beschikbaar ────────────────────────────────────
if command -v gitleaks &>/dev/null; then
  if ! gitleaks detect --exit-code 1 --no-banner 2>/dev/null; then
    echo ""
    echo "BLOCKED: gitleaks detected secrets in repository"
    FOUND_ISSUE=1
  fi
fi

if [ "$FOUND_ISSUE" -eq 1 ]; then
  echo ""
  echo "========================================================"
  echo " PUSH BLOCKED — secrets or personal data detected."
  echo " Fix the issues above, then push again."
  echo "========================================================"
  exit 1
fi

echo "OK: No secrets or personal data detected. Push allowed."
exit 0
