@page "/email-tester"
@inject AdminApiClient Api

<PageTitle>Email-tester — VRC Admin</PageTitle>

<h1>Email-tester (dry-run)</h1>

<div class="alert alert-warning">
    <strong>Let op:</strong> deze test verstuurt niets en slaat niets op.
    De AI wordt wel daadwerkelijk aangeroepen (kost OpenAI credits).
    Rate limit: maximaal 10 calls per minuut.
</div>

<EditForm Model="request" OnValidSubmit="TestAsync">
    <div class="row">
        <div class="col-md-4 mb-3">
            <label class="form-label">Afzender (e-mailadres)</label>
            <input class="form-control" @bind="request.Afzender" placeholder="trainer@example.com" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Afzender naam <small class="text-muted">(voor correcte aanhef)</small></label>
            <input class="form-control" @bind="request.AfzenderNaam" placeholder="Jan de Vries" />
        </div>
        <div class="col-md-4 mb-3">
            <label class="form-label">Onderwerp</label>
            <input class="form-control" @bind="request.Onderwerp" placeholder="Beschikbaarheid 30 maart" />
        </div>
    </div>
    <div class="mb-3">
        <label class="form-label">Body</label>
        <textarea class="form-control" rows="8" @bind="request.Body"
                  placeholder="Hoi, kan VRC JO13-1 op zaterdag 30 maart om 11:00 spelen?"></textarea>
    </div>
    <button type="submit" class="btn btn-primary" disabled="@busy">
        @(busy ? "Bezig..." : "Dry-run classificeren")
    </button>
</EditForm>

@if (response != null)
{
    <hr />
    <h3>Resultaat</h3>
    <div class="card">
        <div class="card-body">
            <h5>Classificatie</h5>
            <pre class="bg-light p-3">@System.Text.Json.JsonSerializer.Serialize(response.Classificatie, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>

            @if (response.PlannerResponse != null)
            {
                <h5 class="mt-4">Planner response</h5>
                <pre class="bg-light p-3">@System.Text.Json.JsonSerializer.Serialize(response.PlannerResponse, new System.Text.Json.JsonSerializerOptions { WriteIndented = true })</pre>
            }

            <h5 class="mt-4">Voorbeeld-antwoord (zou-worden-verstuurd)</h5>
            <p><strong>Onderwerp:</strong> @response.VoorbeeldAntwoord?.Onderwerp</p>
            <pre class="bg-light p-3">@response.VoorbeeldAntwoord?.Body</pre>
        </div>
    </div>
}
@if (!string.IsNullOrEmpty(error))
{
    <div class="alert alert-danger mt-3">@error</div>
}

@code {
    private TestEmailRequest request = new()
    {
        Afzender = "trainer@voorbeeld.nl",
        AfzenderNaam = "Jan de Vries"
    };
    private TestEmailResponse? response;
    private string? error;
    private bool busy;

    private async Task TestAsync()
    {
        busy = true;
        error = null;
        response = null;

        var r = await Api.TestEmailAsync(request);
        if (r.Success) response = r.Data;
        else error = r.ErrorMessage;

        busy = false;
    }
}
