{
  "routes": [
    { "route": "/api/beheer/*", "allowedRoles": ["admin"] },
    { "route": "/api/test/*", "allowedRoles": ["admin"] },
    { "route": "/.auth/login/aad", "allowedRoles": ["anonymous"] },
    { "route": "/*", "allowedRoles": ["authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/aad" }
  },
  "auth": {
    "identityProviders": {
      "azureActiveDirectory": {
        "registration": {
          "openIdIssuer": "https://login.microsoftonline.com/74f2b2fe-a0af-4983-9520-ea3b2ac423fb/v2.0",
          "clientIdSettingName": "AZURE_CLIENT_ID",
          "clientSecretSettingName": "AZURE_CLIENT_SECRET"
        }
      }
    }
  },
  "platform": {
    "apiRuntime": "dotnet-isolated:10.0"
  }
}
