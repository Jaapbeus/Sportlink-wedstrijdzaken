# ── Git hooks ─────────────────────────────────────────────────────────────────
# Sensitive patterns file contains real secrets/passwords used for scanning.
# Copy sensitive-patterns.template.txt → sensitive-patterns.txt and adjust.
.githooks/sensitive-patterns.txt

# ── Azure Functions ───────────────────────────────────────────────────────────
# Local settings contain secrets and machine-specific connection strings.
# Copy local.settings.template.json → local.settings.json and fill in your values.
# NEVER commit local.settings.json
**/local.settings.json

# Azure Storage Emulator (Azurite) — local state files generated at runtime
**/__azurite_db_*.json
**/__blobstorage__/

